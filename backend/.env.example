# Auth0 Application credentials
# Find these in Auth0 Dashboard → Applications → Your App → Settings
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret

# Auth0 Management API audience (not used for login, kept for reference)
AUTH0_AUDIENCE=https://your-tenant.us.auth0.com/api/v2/

# OAuth2 callback URLs
# For local dev, use localhost. For remote access via Tailscale or similar, use your machine's IP.
AUTH0_CALLBACK_URL=http://localhost:8000/auth/callback
AUTH0_CONNECT_CALLBACK_URL=http://localhost:8000/auth/connect-callback
